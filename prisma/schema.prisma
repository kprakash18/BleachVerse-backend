generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Sex {
  MALE
  FEMALE
  UNKNOWN
}

enum CharacterStatus {
  ALIVE
  DEAD
  UNKNOWN
}

model Character {
  id String @id @default(uuid())

  name String @unique

  sex    Sex             @default(UNKNOWN)
  status CharacterStatus @default(ALIVE)

  description String?
  imageUrl    String?

  aliases             CharacterAlias[]
  races               CharacterRace[]
  organizations       CharacterOrganization[]
  fightParticipations FightParticipant[]

  wonFights       Fight[]          @relation("FightWinner")
  transformations Transformation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([sex])
}

model CharacterAlias {
  id String @id @default(uuid())

  characterId String
  alias       String

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([characterId, alias])
  @@index([alias])
}

enum RaceCategory {
  MAIN
  HYBRID
  SPECIAL
  COSMIC
}

model Race {
  id String @id @default(uuid())

  name     String       @unique
  category RaceCategory

  description String?

  characters CharacterRace[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CharacterRace {
  characterId String
  raceId      String

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  race Race @relation(fields: [raceId], references: [id], onDelete: Cascade)

  @@id([characterId, raceId])
}

// organization table creation

enum OrganizationType {
  MILITARY
  FACTION
  ROYAL
  ACADEMY
  OTHER
}

model Organization {
  id String @id @default(uuid())

  name String @unique

  type OrganizationType

  description String?

  parentId String?

  parent Organization? @relation("OrganizationHierarchy", fields: [parentId], references: [id])

  children Organization[] @relation("OrganizationHierarchy")

  members CharacterOrganization[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([parentId])
}

model CharacterOrganization {
  characterId    String
  organizationId String

  role String?

  joinedAt DateTime?
  leftAt   DateTime?

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([characterId, organizationId])
}

// enum for earcs
enum ArcType {
  CANON
  MOVIE
  FILLER
  OVA
}

// episodes arc and episodes
model Arc {
  id          String  @id @default(uuid())
  name        String
  type        ArcType
  description String?

  // anime covering
  startEpisodeNumber Int?
  endEpisodeNumber   Int?

  // maga covering
  startChapter Int?
  endChapter   Int?

  episodes Episode[]
  fights   Fight[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

// enum for episodes
enum EpisodeType {
  FILLER
  CANON
  MIXED
  RECAP
}

// episode model
model Episode {
  id       String      @id @default(uuid())
  number   Int         @unique
  title    String
  type     EpisodeType
  synopsis String?

  airDate DateTime?

  arcId String

  arc             Arc              @relation(fields: [arcId], references: [id], onDelete: Restrict)
  fights          Fight[]
  transformations Transformation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([arcId])
  @@index([type])
}

// fight type enum
enum FightType {
  DUEL
  TEAM_BATTLE
  WAR
  TRAINING
}

// fight model 
model Fight {
  id String @id @default(uuid())

  title    String
  type     FightType @default(DUEL)
  location String?

  summary String?

  episodeId String?
  arcId     String?

  winnerId String?

  episode Episode? @relation(fields: [episodeId], references: [id], onDelete: SetNull)

  arc Arc? @relation(fields: [arcId], references: [id], onDelete: SetNull)

  winner Character? @relation("FightWinner", fields: [winnerId], references: [id], onDelete: SetNull)

  participants         FightParticipant[]
  firstTransformations Transformation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([episodeId])
  @@index([arcId])
  @@index([winnerId])
  @@index([type])
}

// fight outcome type enum
enum FightOutCome {
  WIN
  LOSS
  DRAW
  INTERRUPTED
  UNKNOWN
}

model FightParticipant {
  id String @id @default(uuid())

  fightId String

  characterId String

  outcome FightOutCome @default(UNKNOWN)

  fight Fight @relation(fields: [fightId], references: [id], onDelete: Cascade)

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([fightId, characterId])
  @@index([characterId])
}

// transformation/event 
// because user searches ichigo first bankai

enum TransformationType {
  SHIKAI
  BANKAI
  RESURRECCION
  SEGUNDA_ETAPA
  HOLLOWFICATION
  VOLLSTANDIG
  FULLBRING
  FINAL_FORM
  OTHER
}

model Transformation {
  id             String             @id @default(uuid())
  name           String
  type           TransformationType
  description    String?
  characterId    String
  firstEpisodeId String?
  firstFightId   String?
  character      Character          @relation(fields: [characterId], references: [id], onDelete: Cascade)

  firstEpisode Episode? @relation(fields: [firstEpisodeId], references: [id], onDelete: SetNull)

  firstFight Fight? @relation(fields: [firstFightId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([characterId])
  @@index([type])
}
