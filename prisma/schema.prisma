generator client {
  provider = "prisma-client-js"
}

// generator dbml
generator dbml {
  provider = "prisma-dbml-generator"
}

datasource db {
  provider = "postgresql"
}

// gloabl enums
enum Sex {
  MALE
  FEMALE
  UNKNOWN
}

enum CharacterStatus {
  ALIVE
  DEAD
  UNKNOWN
}

enum SourceMaterial {
  MANGA
  ANIME
  MOVIE
  OVA
  NOVEL
  GAME
}

// ---------------------------------------------------------------------------
// Character
// ---------------------------------------------------------------------------

model Character {
  id   String @id @default(uuid())
  slug String @unique

  name String @unique

  sex    Sex             @default(UNKNOWN)
  status CharacterStatus @default(ALIVE)

  description String?

  aliases       CharacterAlias[]
  races         CharacterRace[]
  organizations CharacterOrganization[]

  images CharacterImage[]

  fightParticipations FightParticipant[]
  wonFights           Fight[]            @relation("FightWinner")

  zanpakutos Zanpakuto[]
  quotes     Quote[]

  transformations   Transformation[]
  powers            Power[]
  appearances       CharacterAppearance[]
  eventParticipants EventParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([sex])
}

model CharacterAlias {
  id String @id @default(uuid())

  characterId String
  alias       String

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([characterId, alias])
  @@index([alias])
}

// ---------------------------------------------------------------------------
// Race
// ---------------------------------------------------------------------------

enum RaceCategory {
  MAIN
  HYBRID
  SPECIAL
  COSMIC
}

model Race {
  id String @id @default(uuid())

  name     String       @unique
  category RaceCategory

  description String?

  characters CharacterRace[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CharacterRace {
  characterId String
  raceId      String

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  race      Race      @relation(fields: [raceId], references: [id], onDelete: Cascade)

  @@id([characterId, raceId])
}

// ---------------------------------------------------------------------------
// Organization
// ---------------------------------------------------------------------------

enum OrganizationType {
  MILITARY
  FACTION
  ROYAL
  ACADEMY
  OTHER
}

model Organization {
  id   String @id @default(uuid())
  slug String @unique

  name String @unique

  type OrganizationType

  description String?

  parentId String?

  parent   Organization?  @relation("OrganizationHierarchy", fields: [parentId], references: [id])
  children Organization[] @relation("OrganizationHierarchy")

  members CharacterOrganization[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([parentId])
}

model CharacterOrganization {
  id             String @id @default(uuid())
  characterId    String
  organizationId String

  role String?

  joinedAt DateTime?
  leftAt   DateTime?

  character    Character    @relation(fields: [characterId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([characterId])
  @@index([organizationId])
  @@index([characterId, leftAt])
  @@index([organizationId, leftAt])
}

// ---------------------------------------------------------------------------
// Arc & Episode
// ---------------------------------------------------------------------------

enum ArcType {
  CANON
  MOVIE
  FILLER
  OVA
}

model Arc {
  id   String @id @default(uuid())
  slug String @unique

  name        String  @unique
  type        ArcType
  description String?

  // anime covering
  startEpisodeNumber Int?
  endEpisodeNumber   Int?

  // manga covering
  startChapter Int?
  endChapter   Int?

  episodes Episode[]
  fights   Fight[]
  quotes   Quote[]
  events   Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

// enum for episodes types
enum EpisodeType {
  FILLER
  CANON
  MIXED
  RECAP
}

// episode model
model Episode {
  id       String      @id @default(uuid())
  number   Int         @unique
  title    String
  type     EpisodeType
  synopsis String?

  airDate DateTime?

  arcId String

  arc             Arc                   @relation(fields: [arcId], references: [id], onDelete: Restrict)
  fights          Fight[]
  transformations Transformation[]      @relation("TransformationFirstEpisode")
  quotes          Quote[]
  appearances     CharacterAppearance[]
  events          Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([arcId])
  @@index([type])
  @@index([airDate])
}

// ---------------------------------------------------------------------------
// Fight
// ---------------------------------------------------------------------------

enum FightType {
  DUEL
  TEAM_BATTLE
  WAR
  TRAINING
}

// fight model 
model Fight {
  id String @id @default(uuid())

  title String
  type  FightType @default(DUEL)

  summary String?

  episodeId  String?
  arcId      String?
  locationId String?
  winnerId   String?

  episode  Episode?   @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  arc      Arc?       @relation(fields: [arcId], references: [id], onDelete: SetNull)
  location Location?  @relation(fields: [locationId], references: [id], onDelete: SetNull)
  winner   Character? @relation("FightWinner", fields: [winnerId], references: [id], onDelete: SetNull)

  participants         FightParticipant[]
  firstTransformations Transformation[]   @relation("TransformationFirstFight")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([episodeId])
  @@index([arcId])
  @@index([winnerId])
  @@index([type])
  @@index([locationId])
}

enum FightOutcome {
  WIN
  LOSS
  DRAW
  INTERRUPTED
  UNKNOWN
}

model FightParticipant {
  id String @id @default(uuid())

  fightId     String
  characterId String

  outcome FightOutcome @default(UNKNOWN)

  fight     Fight     @relation(fields: [fightId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([fightId, characterId])
  @@index([characterId])
  @@index([fightId])
}

// ---------------------------------------------------------------------------
// Transformation
// ---------------------------------------------------------------------------

enum TransformationType {
  SHIKAI
  BANKAI
  RESURRECCION
  SEGUNDA_ETAPA
  HOLLOWFICATION
  VOLLSTANDIG
  FULLBRING
  FINAL_FORM
  OTHER
}

model Transformation {
  id             String             @id @default(uuid())
  name           String
  type           TransformationType
  description    String?
  isCanonical    Boolean            @default(true)
  sourceMaterial SourceMaterial     @default(MANGA)
  characterId    String
  zanpakutoId    String?
  firstEpisodeId String?
  firstFightId   String?

  character    Character  @relation(fields: [characterId], references: [id], onDelete: Cascade)
  zanpakuto    Zanpakuto? @relation(fields: [zanpakutoId], references: [id], onDelete: SetNull)
  firstEpisode Episode?   @relation("TransformationFirstEpisode", fields: [firstEpisodeId], references: [id], onDelete: SetNull)
  firstFight   Fight?     @relation("TransformationFirstFight", fields: [firstFightId], references: [id], onDelete: SetNull)

  powers Power[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([characterId])
  @@index([type])
  @@index([firstEpisodeId])
  @@index([firstFightId])
  @@index([zanpakutoId])
}

// ---------------------------------------------------------------------------
// Power
// ---------------------------------------------------------------------------

enum PowerType {
  OFFENSIVE
  DEFENSIVE
  SUPPORT
  HEALING
  MOVEMENT
  PASSIVE
  OTHER
}

// source of the power
enum PowerSource {
  ZANPAKUTO
  KIDO
  HOLLOW
  QUINCY
  FULLBRING
  NATURAL
  OTHER
}

model Power {
  id String @id @default(uuid())

  name           String
  type           PowerType
  source         PowerSource
  description    String?
  isCanonical    Boolean        @default(true)
  sourceMaterial SourceMaterial @default(MANGA)

  characterId      String
  transformationId String?

  character      Character       @relation(fields: [characterId], references: [id], onDelete: Cascade)
  transformation Transformation? @relation(fields: [transformationId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([characterId])
  @@index([type])
  @@index([source])
  @@index([transformationId])
}

// ---------------------------------------------------------------------------
// Zanpakuto
// ---------------------------------------------------------------------------

enum ZanpakutoType {
  NORMAL
  DUAL
  HYBRID
}

model Zanpakuto {
  id   String @id @default(uuid())
  slug String @unique

  name String @unique

  type ZanpakutoType @default(NORMAL)

  releaseCommand String?
  spiritName     String?
  description    String?

  characterId String

  character       Character        @relation(fields: [characterId], references: [id], onDelete: Cascade)
  transformations Transformation[]
  aliases         ZanpakutoAlias[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([characterId])
}

model ZanpakutoAlias {
  id String @id @default(uuid())

  zanpakutoId String
  alias       String

  zanpakuto Zanpakuto @relation(fields: [zanpakutoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([zanpakutoId, alias])
  @@index([alias])
}

// ---------------------------------------------------------------------------
// Quote
// ---------------------------------------------------------------------------

enum QuoteCategory {
  MOTIVATIONAL
  PHILOSOPHICAL
  COMEDY
  THREAT
  BATTLE
  EMOTIONAL
  OTHER
}

// famous quotes by characters
model Quote {
  id String @id @default(uuid())

  text           String         @db.Text
  category       QuoteCategory  @default(OTHER)
  isCanonical    Boolean        @default(true)
  sourceMaterial SourceMaterial @default(MANGA)

  characterId String
  episodeId   String?
  arcId       String?

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  episode   Episode?  @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  arc       Arc?      @relation(fields: [arcId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([characterId])
  @@index([episodeId])
  @@index([arcId])
  @@index([category])
}

// ---------------------------------------------------------------------------
// Location
// ---------------------------------------------------------------------------

enum LocationType {
  WORLD
  REGION
  STRUCTURE
  OTHER
}

model Location {
  id   String @id @default(uuid())
  slug String @unique

  name String @unique

  type LocationType

  description String?

  parentId String?

  parent   Location?  @relation("LocationHierarchy", fields: [parentId], references: [id])
  children Location[] @relation("LocationHierarchy")

  fights Fight[]
  events Event[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([parentId])
}

// ---------------------------------------------------------------------------
// CharacterAppearance & CharacterImage
// ---------------------------------------------------------------------------

model CharacterAppearance {
  id String @id @default(uuid())

  characterId String
  episodeId   String

  isFirstAppearance Boolean @default(false)

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  episode   Episode   @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([characterId, episodeId])
  @@index([characterId])
  @@index([episodeId])
}

enum CharacterImageType {
  PROFILE
  ANIME
  MANGA
  BANKAI
  SHIKAI
  TYBW
  PROMOTIONAL
  OTHER
}

model CharacterImage {
  id String @id @default(uuid())

  characterId String
  imageUrl    String
  type        CharacterImageType @default(PROFILE)
  source      String?
  altText     String?
  isPrimary   Boolean            @default(false)
  sortOrder   Int                @default(0)

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([characterId])
  @@index([type])
  @@index([isPrimary])
  @@index([characterId, isPrimary])
}

// ---------------------------------------------------------------------------
// Event
// ---------------------------------------------------------------------------

enum EventType {
  BATTLE
  DEATH
  REVEAL
  BETRAYAL
  TRANSFORMATION
  POWER_GAIN
  POWER_LOSS
  RESCUE
  INVASION
  OTHER
}

model Event {
  id String @id @default(uuid())

  title          String
  type           EventType
  description    String?
  isCanonical    Boolean        @default(true)
  sourceMaterial SourceMaterial @default(MANGA)

  episodeId  String?
  arcId      String?
  locationId String?

  episode  Episode?  @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  arc      Arc?      @relation(fields: [arcId], references: [id], onDelete: SetNull)
  location Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  participants EventParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([episodeId])
  @@index([arcId])
  @@index([locationId])
}

model EventParticipant {
  id String @id @default(uuid())

  eventId     String
  characterId String

  role String?

  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([eventId, characterId])
  @@index([characterId])
  @@index([eventId])
}
